{
  "name": "image-tools-hub",
  "version": "3.0.0",
  "description": "منصة متكاملة لتحرير الصور: ضغط، إزالة الخلفية، تحويل الصيغ",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "build": "npm install",
    "clean": "rm -rf node_modules package-lock.json uploads logs images_db.json",
    "setup": "npm install && mkdir -p uploads logs public"
  },
  "keywords": [
    "image-compressor",
    "background-remover",
    "image-converter",
    "image-tools",
    "remove-background",
    "compress-image",
    "png-to-jpg",
    "webp-converter",
    "image-editor",
    "free-image-tools"
  ],
  "author": {
    "name": "Image Tools Hub",
    "email": "support@imagetoolshub.com",
    "url": "https://imagetoolshub.com"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/imagetoolshub/image-tools-hub"
  },
  "bugs": {
    "url": "https://github.com/imagetoolshub/image-tools-hub/issues"
  },
  "homepage": "https://imagetoolshub.com",
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "dependencies": {
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "form-data": "^4.0.5",
    "fs-extra": "^11.1.1",
    "helmet": "^7.1.0",
    "multer": "^1.4.5-lts.1",
    "node-fetch": "^2.7.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  },
  "files": [
    "server.js",
    "public/",
    "uploads/",
    "logs/",
    "package.json",
    "README.md",
    ".env.example"
  ],
  "directories": {
    "public": "public",
    "uploads": "uploads",
    "logs": "logs"
  }
}
