```env
# ============================================================================
# IMAGE TOOLS HUB - ENVIRONMENT VARIABLES
# ============================================================================

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================
# Port number for the server (default: 3000)
PORT=3000

# Node environment (development, production, test)
NODE_ENV=development

# Host address (0.0.0.0 for all interfaces, localhost for local only)
HOST=0.0.0.0

# ============================================================================
# API KEYS
# ============================================================================
# Remove.bg API Key - Get your free API key from https://www.remove.bg/
# The free tier allows 50 requests per month
REMOVE_BG_API_KEY=6Q4rXsndcj3dymPVhrDt4p78

# Optional: ImageKit.io API Key for image optimization (if needed)
# IMAGEKIT_PUBLIC_KEY=your_public_key
# IMAGEKIT_PRIVATE_KEY=your_private_key
# IMAGEKIT_URL_ENDPOINT=your_url_endpoint

# Optional: Cloudinary API Key (alternative)
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret

# ============================================================================
# ADMIN PANEL CREDENTIALS
# ============================================================================
# Admin username (change this for security)
ADMIN_USERNAME=admin

# Admin password (change this for security - use strong password)
ADMIN_PASSWORD=admin123

# Session secret for admin authentication (generate a random string)
ADMIN_SESSION_SECRET=image-tools-hub-secret-key-2025

# ============================================================================
# FILE UPLOAD LIMITS
# ============================================================================
# Maximum file size in megabytes (default: 10)
MAX_FILE_SIZE_MB=10

# Maximum file size in bytes (calculated automatically)
# MAX_FILE_SIZE_BYTES=10485760

# Allowed file types (comma separated)
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp,image/jpg,image/gif

# ============================================================================
# RATE LIMITING
# ============================================================================
# Maximum number of requests per IP per window
RATE_LIMIT_MAX=100

# Rate limit window in minutes
RATE_LIMIT_WINDOW_MS=60000

# ============================================================================
# CORS CONFIGURATION
# ============================================================================
# Allowed origins (comma separated, use * for all - not recommended for production)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,https://imagetoolshub.com

# ============================================================================
# LOGGING CONFIGURATION
# ============================================================================
# Log level (error, warn, info, debug)
LOG_LEVEL=info

# Log to file (true/false)
LOG_TO_FILE=true

# Log directory path
LOG_DIRECTORY=./logs

# ============================================================================
# DATABASE (JSON FILES)
# ============================================================================
# Images database file path
IMAGES_DB_FILE=./images_db.json

# Maximum number of records to keep (to prevent file bloat)
MAX_DB_RECORDS=1000

# ============================================================================
# EMAIL CONFIGURATION (for contact form)
# ============================================================================
# SMTP settings (optional - for sending emails)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your_email@gmail.com
# SMTP_PASS=your_app_password
# CONTACT_EMAIL=contact@imagetoolshub.com

# ============================================================================
# SECURITY
# ============================================================================
# Enable Helmet.js security headers (true/false)
ENABLE_HELMET=true

# Enable compression (true/false)
ENABLE_COMPRESSION=true

# Trust proxy (true/false - set to true if behind reverse proxy)
TRUST_PROXY=false

# ============================================================================
# PERFORMANCE
# ============================================================================
# Image processing quality (0-100)
IMAGE_QUALITY=80

# Maximum image dimension for resizing (pixels)
MAX_IMAGE_DIMENSION=1920

# Cache control max age (seconds)
CACHE_MAX_AGE=86400

# ============================================================================
# FEATURE TOGGLES
# ============================================================================
# Enable background removal feature (true/false)
ENABLE_BG_REMOVAL=true

# Enable image compression feature (true/false)
ENABLE_COMPRESSION_FEATURE=true

# Enable image conversion feature (true/false)
ENABLE_CONVERSION=true

# Enable analytics (true/false)
ENABLE_ANALYTICS=true

# ============================================================================
# MAINTENANCE MODE
# ============================================================================
# Enable maintenance mode (true/false)
MAINTENANCE_MODE=false

# Maintenance message
MAINTENANCE_MESSAGE=The site is under maintenance. Please check back later.

# ============================================================================
# END OF ENVIRONMENT VARIABLES
# ============================================================================
```